# =============================================================================
# Wheeled Bipedal Robot Simulation — .gitignore
# =============================================================================

# ─── Python bytecode ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ─── Virtual environments ────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env

# ─── Build / packaging ───────────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg
MANIFEST

# ─── Training outputs (checkpoints, logs, telemetry) ─────────────────────────
outputs/
runs/
wandb/
logs/

# ─── MuJoCo runtime logs ─────────────────────────────────────────────────────
MUJOCO_LOG.TXT
mujoco_log.txt

# ─── Testing & linting caches ────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ─── Jupyter ─────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ─── OS / editor artifacts ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ─── Binary outputs ───────────────────────────────────────────────────────────
*.mp4
*.avi
*.gif

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.log
*.bak
*.tmp
