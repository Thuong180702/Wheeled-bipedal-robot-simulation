<!--
  ============================================================
  Wheeled Bipedal Robot - MuJoCo MJCF Model
  ============================================================
  Thông số:
    - Đùi: 35cm, Ống chân: 35cm, Bánh xe: Ø12cm
    - Tổng khối lượng: ~7kg
    - 10 động cơ: Hip Roll/Pitch, Knee, Ankle, Wheel (×2)
    - Cảm biến: IMU (accel + gyro) + 10 encoder

  Hệ tọa độ:
    - X: trái/phải (lateral)
    - Y: tiến (phía trước) — KHÁC với wheeled_biped_real.xml (-Y = forward)
    - Z: lên
  ============================================================
-->
<mujoco model="wheeled_biped">

  <!-- ==================== COMPILER ==================== -->
  <compiler angle="radian" autolimits="true"/>

  <!-- ==================== OPTIONS ==================== -->
  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast"
          iterations="4" ls_iterations="8" cone="pyramidal">
    <flag contact="enable"/>
  </option>

  <!-- ==================== SIZE ==================== -->
  <size nconmax="200" njmax="500"/>

  <!-- ==================== DEFAULTS ==================== -->
  <default>
    <!-- Mặc định toàn cục -->
    <default class="robot">
      <joint damping="1.0" armature="0.01" frictionloss="0.1"/>
      <geom condim="3" contype="1" conaffinity="1" friction="0.8 0.02 0.01"
            rgba="0.35 0.35 0.35 1"/>
      <motor ctrllimited="true"/>
    </default>

    <!-- Khớp khung chân -->
    <default class="leg_link">
      <geom type="capsule" size="0.025" rgba="0.25 0.25 0.28 1"/>
    </default>

    <!-- Khớp motor (hiển thị) -->
    <default class="motor_visual">
      <geom type="cylinder" size="0.032 0.018" contype="0" conaffinity="0"
            group="1" rgba="0.15 0.15 0.8 0.8"/>
    </default>

    <!-- Bánh xe -->
    <default class="wheel">
      <geom type="cylinder" condim="6" friction="1.5 0.005 0.001"
            rgba="0.12 0.12 0.12 1" priority="1"/>
    </default>
  </default>

  <!-- ==================== ASSETS ==================== -->
  <asset>
    <!-- Texture mặt đất -->
    <texture name="grid_tex" type="2d" builtin="checker" width="512" height="512"
             rgb1="0.12 0.18 0.25" rgb2="0.22 0.28 0.35"/>
    <material name="grid_mat" texture="grid_tex" texrepeat="10 10"
              reflectance="0.1"/>

    <!-- Material robot -->
    <material name="body_mat"  rgba="0.35 0.38 0.40 1" specular="0.5" shininess="0.3"/>
    <material name="leg_mat"   rgba="0.25 0.25 0.28 1" specular="0.3"/>
    <material name="wheel_mat" rgba="0.10 0.10 0.10 1" specular="0.1"/>
    <material name="motor_mat" rgba="0.15 0.15 0.70 0.9"/>
  </asset>

  <!-- ==================== WORLDBODY ==================== -->
  <worldbody>
    <!-- Ánh sáng -->
    <light name="top_light"    pos="0 0 3" dir="0 0 -1" diffuse="0.8 0.8 0.8"
           specular="0.3 0.3 0.3" castshadow="true"/>
    <light name="front_light"  pos="2 -2 2" dir="-1 1 -0.5" diffuse="0.4 0.4 0.4"/>

    <!-- Mặt đất -->
    <geom name="floor" type="plane" size="50 50 0.1" material="grid_mat"
          condim="3" contype="1" conaffinity="1"/>

    <!-- ==================== ROBOT BODY ==================== -->
    <body name="torso" pos="0 0 0.75">
      <freejoint name="root"/>

      <!-- Thân robot (contype=0: MJX không hỗ trợ cylinder-box collision) -->
      <geom name="torso_box" type="box" size="0.10 0.08 0.06"
            material="body_mat" mass="2.0" contype="0" conaffinity="0"/>

      <!-- Điểm gắn cảm biến IMU -->
      <site name="imu_site" pos="0 0 0" size="0.005" rgba="1 0 0 0.5"/>

      <!-- Điểm theo dõi trọng tâm -->
      <site name="torso_com" pos="0 0 0" size="0.01" rgba="0 1 0 0.3"/>

      <!-- =====================================================
           CHÂN TRÁI
           ===================================================== -->
      <body name="l_hip_roll_link" pos="0 0.075 -0.04">
        <inertial mass="0.4" pos="0 0.01 0"
                  diaginertia="0.0004 0.0004 0.0003"/>
        <joint name="l_hip_roll" type="hinge" axis="1 0 0"
               range="-0.5 0.5" damping="1.5" armature="0.02" ref="0"/>
        <geom name="l_hip_roll_motor" class="motor_visual"
              euler="0 1.5708 0" pos="0 0.02 0"
              rgba="0.15 0.75 0.15 0.8"/>

        <body name="l_hip_pitch_link" pos="0 0 0">
          <inertial mass="0.4" pos="0 0 -0.03"
                    diaginertia="0.0004 0.0004 0.0003"/>
          <joint name="l_hip_pitch" type="hinge" axis="0 1 0"
                 range="-1.5 1.5" damping="1.5" armature="0.02" ref="0"/>
          <geom name="l_hip_pitch_motor" class="motor_visual"
                pos="0 0 -0.01"/>

          <!-- Đùi trái (0.35m) -->
          <body name="l_thigh" pos="0 0 -0.04">
            <inertial mass="0.55" pos="0 0 -0.175"
                      diaginertia="0.0060 0.0060 0.0005"/>
            <geom name="l_thigh_geom" class="leg_link"
                  fromto="0 0 0  0 0 -0.35" material="leg_mat"
                  mass="0.55"/>
            <site name="l_thigh_center" pos="0 0 -0.175" size="0.005"/>

            <!-- Gối trái -->
            <body name="l_knee_link" pos="0 0 -0.35">
              <inertial mass="0.55" pos="0 0 -0.175"
                        diaginertia="0.0060 0.0060 0.0005"/>
              <joint name="l_knee" type="hinge" axis="0 1 0"
                     range="0.05 2.8" damping="1.5" armature="0.02" ref="0"/>
              <geom name="l_knee_motor" class="motor_visual"
                    pos="0 0 -0.005"/>
              <geom name="l_shin_geom" class="leg_link"
                    fromto="0 0 0  0 0 -0.35" material="leg_mat"
                    mass="0.55"/>
              <site name="l_shin_center" pos="0 0 -0.175" size="0.005"/>

              <!-- Cổ chân trái -->
              <body name="l_ankle_link" pos="0 0 -0.35">
                <inertial mass="0.15" pos="0 0 -0.01"
                          diaginertia="0.0002 0.0002 0.0001"/>
                <joint name="l_ankle" type="hinge" axis="0 1 0"
                       range="-1.0 1.0" damping="0.8" armature="0.01" ref="0"/>
                <geom name="l_ankle_motor" class="motor_visual"
                      size="0.028 0.015" pos="0 0 -0.005"/>

                <!-- Cảm biến tiếp xúc chân trái -->
                <site name="l_foot_contact" pos="0 0 -0.02"
                      size="0.02" rgba="1 1 0 0.3"/>

                <!-- Bánh xe trái -->
                <body name="l_wheel_link" pos="0 0 -0.025">
                  <inertial mass="0.55" pos="0 0 0"
                            diaginertia="0.0012 0.0018 0.0012"/>
                  <joint name="l_wheel" type="hinge" axis="0 1 0"
                         limited="false" damping="0.02" armature="0.008"/>
                  <geom name="l_wheel_geom" class="wheel"
                        size="0.06 0.02" euler="1.5708 0 0"
                        material="wheel_mat" mass="0.55"/>
                  <site name="l_wheel_contact" pos="0 0 -0.06"
                        size="0.01" rgba="1 0.5 0 0.3"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>

      <!-- =====================================================
           CHÂN PHẢI (đối xứng qua y=0)
           ===================================================== -->
      <body name="r_hip_roll_link" pos="0 -0.075 -0.04">
        <inertial mass="0.4" pos="0 -0.01 0"
                  diaginertia="0.0004 0.0004 0.0003"/>
        <joint name="r_hip_roll" type="hinge" axis="1 0 0"
               range="-0.5 0.5" damping="1.5" armature="0.02" ref="0"/>
        <geom name="r_hip_roll_motor" class="motor_visual"
              euler="0 1.5708 0" pos="0 -0.02 0"
              rgba="0.15 0.75 0.15 0.8"/>

        <body name="r_hip_pitch_link" pos="0 0 0">
          <inertial mass="0.4" pos="0 0 -0.03"
                    diaginertia="0.0004 0.0004 0.0003"/>
          <joint name="r_hip_pitch" type="hinge" axis="0 1 0"
                 range="-1.5 1.5" damping="1.5" armature="0.02" ref="0"/>
          <geom name="r_hip_pitch_motor" class="motor_visual"
                pos="0 0 -0.01"/>

          <!-- Đùi phải (0.35m) -->
          <body name="r_thigh" pos="0 0 -0.04">
            <inertial mass="0.55" pos="0 0 -0.175"
                      diaginertia="0.0060 0.0060 0.0005"/>
            <geom name="r_thigh_geom" class="leg_link"
                  fromto="0 0 0  0 0 -0.35" material="leg_mat"
                  mass="0.55"/>
            <site name="r_thigh_center" pos="0 0 -0.175" size="0.005"/>

            <!-- Gối phải -->
            <body name="r_knee_link" pos="0 0 -0.35">
              <inertial mass="0.55" pos="0 0 -0.175"
                        diaginertia="0.0060 0.0060 0.0005"/>
              <joint name="r_knee" type="hinge" axis="0 1 0"
                     range="0.05 2.8" damping="1.5" armature="0.02" ref="0"/>
              <geom name="r_knee_motor" class="motor_visual"
                    pos="0 0 -0.005"/>
              <geom name="r_shin_geom" class="leg_link"
                    fromto="0 0 0  0 0 -0.35" material="leg_mat"
                    mass="0.55"/>
              <site name="r_shin_center" pos="0 0 -0.175" size="0.005"/>

              <!-- Cổ chân phải -->
              <body name="r_ankle_link" pos="0 0 -0.35">
                <inertial mass="0.15" pos="0 0 -0.01"
                          diaginertia="0.0002 0.0002 0.0001"/>
                <joint name="r_ankle" type="hinge" axis="0 1 0"
                       range="-1.0 1.0" damping="0.8" armature="0.01" ref="0"/>
                <geom name="r_ankle_motor" class="motor_visual"
                      size="0.028 0.015" pos="0 0 -0.005"/>

                <!-- Cảm biến tiếp xúc chân phải -->
                <site name="r_foot_contact" pos="0 0 -0.02"
                      size="0.02" rgba="1 1 0 0.3"/>

                <!-- Bánh xe phải -->
                <body name="r_wheel_link" pos="0 0 -0.025">
                  <inertial mass="0.55" pos="0 0 0"
                            diaginertia="0.0012 0.0018 0.0012"/>
                  <joint name="r_wheel" type="hinge" axis="0 1 0"
                         limited="false" damping="0.02" armature="0.008"/>
                  <geom name="r_wheel_geom" class="wheel"
                        size="0.06 0.02" euler="1.5708 0 0"
                        material="wheel_mat" mass="0.55"/>
                  <site name="r_wheel_contact" pos="0 0 -0.06"
                        size="0.01" rgba="1 0.5 0 0.3"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>

    </body>  <!-- end torso -->
  </worldbody>

  <!-- ==================== CONTACT ==================== -->
  <contact>
    <!-- Loại trừ va chạm nội bộ giữa các link liền kề -->
    <exclude body1="torso"          body2="l_hip_roll_link"/>
    <exclude body1="torso"          body2="r_hip_roll_link"/>
    <exclude body1="l_hip_roll_link" body2="l_hip_pitch_link"/>
    <exclude body1="r_hip_roll_link" body2="r_hip_pitch_link"/>
    <exclude body1="l_hip_pitch_link" body2="l_thigh"/>
    <exclude body1="r_hip_pitch_link" body2="r_thigh"/>
    <exclude body1="l_thigh"        body2="l_knee_link"/>
    <exclude body1="r_thigh"        body2="r_knee_link"/>
    <exclude body1="l_knee_link"    body2="l_ankle_link"/>
    <exclude body1="r_knee_link"    body2="r_ankle_link"/>
    <exclude body1="l_ankle_link"   body2="l_wheel_link"/>
    <exclude body1="r_ankle_link"   body2="r_wheel_link"/>
    <!-- Loại trừ va chạm giữa shin và wheel (cách 1 link) -->
    <exclude body1="l_knee_link"    body2="l_wheel_link"/>
    <exclude body1="r_knee_link"    body2="r_wheel_link"/>
    <!-- Loại trừ va chạm thigh-torso (cách 2 link) -->
    <exclude body1="torso"          body2="l_thigh"/>
    <exclude body1="torso"          body2="r_thigh"/>
    <!-- Loại trừ torso với các body xa hơn -->
    <exclude body1="torso"          body2="l_knee_link"/>
    <exclude body1="torso"          body2="r_knee_link"/>
    <exclude body1="torso"          body2="l_ankle_link"/>
    <exclude body1="torso"          body2="r_ankle_link"/>
    <exclude body1="torso"          body2="l_wheel_link"/>
    <exclude body1="torso"          body2="r_wheel_link"/>
    <!-- Loại trừ va chạm giữa 2 chân cùng level -->
    <exclude body1="l_hip_roll_link" body2="r_hip_roll_link"/>
  </contact>

  <!-- ==================== ACTUATORS (10 động cơ) ==================== -->
  <actuator>
    <!-- Chân trái -->
    <motor name="l_hip_roll_motor"  joint="l_hip_roll"  gear="1"
           ctrlrange="-15 15"  forcelimited="true" forcerange="-15 15"/>
    <motor name="l_hip_pitch_motor" joint="l_hip_pitch" gear="1"
           ctrlrange="-15 15"  forcelimited="true" forcerange="-15 15"/>
    <motor name="l_knee_motor"      joint="l_knee"      gear="1"
           ctrlrange="-15 15"  forcelimited="true" forcerange="-15 15"/>
    <motor name="l_ankle_motor"     joint="l_ankle"     gear="1"
           ctrlrange="-10 10"  forcelimited="true" forcerange="-10 10"/>
    <motor name="l_wheel_motor"     joint="l_wheel"     gear="1"
           ctrlrange="-10 10"  forcelimited="true" forcerange="-10 10"/>

    <!-- Chân phải -->
    <motor name="r_hip_roll_motor"  joint="r_hip_roll"  gear="1"
           ctrlrange="-15 15"  forcelimited="true" forcerange="-15 15"/>
    <motor name="r_hip_pitch_motor" joint="r_hip_pitch" gear="1"
           ctrlrange="-15 15"  forcelimited="true" forcerange="-15 15"/>
    <motor name="r_knee_motor"      joint="r_knee"      gear="1"
           ctrlrange="-15 15"  forcelimited="true" forcerange="-15 15"/>
    <motor name="r_ankle_motor"     joint="r_ankle"     gear="1"
           ctrlrange="-10 10"  forcelimited="true" forcerange="-10 10"/>
    <motor name="r_wheel_motor"     joint="r_wheel"     gear="1"
           ctrlrange="-10 10"  forcelimited="true" forcerange="-10 10"/>
  </actuator>

  <!-- ==================== SENSORS ==================== -->
  <sensor>
    <!-- === IMU (cảm biến gia tốc + con quay hồi chuyển) === -->
    <accelerometer name="imu_accel"  site="imu_site"/>
    <gyro          name="imu_gyro"   site="imu_site"/>
    <framequat     name="imu_quat"   objtype="site" objname="imu_site"/>

    <!-- === Encoder vị trí khớp (10 khớp) === -->
    <jointpos name="l_hip_roll_pos"  joint="l_hip_roll"/>
    <jointpos name="l_hip_pitch_pos" joint="l_hip_pitch"/>
    <jointpos name="l_knee_pos"      joint="l_knee"/>
    <jointpos name="l_ankle_pos"     joint="l_ankle"/>
    <jointpos name="l_wheel_pos"     joint="l_wheel"/>
    <jointpos name="r_hip_roll_pos"  joint="r_hip_roll"/>
    <jointpos name="r_hip_pitch_pos" joint="r_hip_pitch"/>
    <jointpos name="r_knee_pos"      joint="r_knee"/>
    <jointpos name="r_ankle_pos"     joint="r_ankle"/>
    <jointpos name="r_wheel_pos"     joint="r_wheel"/>

    <!-- === Encoder vận tốc khớp (10 khớp) === -->
    <jointvel name="l_hip_roll_vel"  joint="l_hip_roll"/>
    <jointvel name="l_hip_pitch_vel" joint="l_hip_pitch"/>
    <jointvel name="l_knee_vel"      joint="l_knee"/>
    <jointvel name="l_ankle_vel"     joint="l_ankle"/>
    <jointvel name="l_wheel_vel"     joint="l_wheel"/>
    <jointvel name="r_hip_roll_vel"  joint="r_hip_roll"/>
    <jointvel name="r_hip_pitch_vel" joint="r_hip_pitch"/>
    <jointvel name="r_knee_vel"      joint="r_knee"/>
    <jointvel name="r_ankle_vel"     joint="r_ankle"/>
    <jointvel name="r_wheel_vel"     joint="r_wheel"/>

    <!-- === Lực tiếp xúc (ước lượng từ torque cảm biến) === -->
    <torque name="l_ankle_torque" site="l_foot_contact"/>
    <torque name="r_ankle_torque" site="r_foot_contact"/>
  </sensor>

  <!-- ==================== KEYFRAME (tư thế khởi đầu) ==================== -->
  <!-- qpos: [root_pos(3) root_quat(4) | l_hip_roll l_hip_pitch l_knee l_ankle l_wheel |
                                          r_hip_roll r_hip_pitch r_knee r_ankle r_wheel] -->
  <keyframe>
    <key name="standing"
         qpos="0 0 0.68
               1 0 0 0
               0 -0.72 1.44 -0.72 0
               0 -0.72 1.44 -0.72 0"
         ctrl="0 1.8 -2.2 0 0
               0 1.8 -2.2 0 0"/>
  </keyframe>

</mujoco>
